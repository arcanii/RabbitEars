<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- CMake substitutes the MACOSX_BUNDLE placeholders below from the target
     properties set in mac/CMakeLists.txt. TODO(phase-1): confirm the bundle id
     matches the family's real macOS identifier, and add the Sparkle
     SUFeedURL / SUPublicEDKey keys once Sparkle is provisioned. -->
<plist version="1.0">
<dict>
  <key>CFBundleName</key>              <string>${MACOSX_BUNDLE_BUNDLE_NAME}</string>
  <key>CFBundleDisplayName</key>       <string>RabbitEars</string>
  <key>CFBundleExecutable</key>        <string>${MACOSX_BUNDLE_EXECUTABLE_NAME}</string>
  <key>CFBundleIdentifier</key>        <string>${MACOSX_BUNDLE_GUI_IDENTIFIER}</string>
  <key>CFBundleShortVersionString</key><string>${MACOSX_BUNDLE_SHORT_VERSION_STRING}</string>
  <key>CFBundleVersion</key>           <string>${MACOSX_BUNDLE_BUNDLE_VERSION}</string>
  <key>CFBundlePackageType</key>       <string>APPL</string>
  <key>LSMinimumSystemVersion</key>    <string>11.0</string>
  <key>NSHighResolutionCapable</key>   <true/>
  <key>NSPrincipalClass</key>          <string>NSApplication</string>
  <!-- Sparkle auto-update: the macOS appcast + the shared family Ed25519 public
       key (same string as the Windows WinSparkle build). Ignored when Sparkle
       isn't linked. Live end-to-end update needs a signed/notarized release. -->
  <key>SUFeedURL</key>              <string>https://raw.githubusercontent.com/arcanii/RabbitEars/main/mac/packaging/appcast-mac.xml</string>
  <key>SUPublicEDKey</key>          <string>sKPprIa95Hw+DX3bMoxWMsyC0w9vc4MzEpgx7TBDP1I=</string>
  <key>SUEnableAutomaticChecks</key><true/>
</dict>
</plist>
