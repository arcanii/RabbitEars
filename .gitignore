# Build output
/build/
/build-arm64/
/out/
/build-mac/
/build-mac-universal/
/build-xcode/
/mac/build/

# libVLC provisioning download (re-fetched at configure time)
/build/libvlc_pkg/
*.nupkg

# Large candidate art variants not used by the build (the build uses only
# art/RabbitEars.png and art/RabbitEars_icon.png).
/art/A_*.png

# Stray/scratch images dropped at the repo root (real art lives in art/*.png).
/*.jpg

# Debug/probe artifacts
/build/rabbitears_debug.log

# Editor / OS cruft
.vs/
*.user
.DS_Store
Thumbs.db
desktop.ini

# i18n review sheets are generated on demand from the JSON (tools/i18n/gen_i18n.py --review <code>)
common/i18n/review-*.md
